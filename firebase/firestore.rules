rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }
    function ownsDevice(deviceId) {
      return signedIn()
        && get(/databases/$(database)/documents/devices/$(deviceId)).data.ownerUid == request.auth.uid;
    }
    match /devices/{deviceId} {
      allow read, update: if ownsDevice(deviceId);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if false;
      match /schedules/{scheduleId} {
        allow read, write: if ownsDevice(deviceId);
      }
      match /logs/{logId} {
        allow read: if ownsDevice(deviceId);
        allow write: if false;
      }
    }
  }
}
